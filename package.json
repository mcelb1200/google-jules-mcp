{
  "name": "jclaw",
  "version": "1.0.0",
  "description": "MCP server for Google Jules integration - automate tasks, code reviews, and repository management",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "jclaw": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/ --ext .ts",
    "lint:fix": "eslint src/ test/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "ci": "npm run format:check && npm run lint && npm run build && npm run test:coverage",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.1",
    "axios": "^1.10.0",
    "playwright": "^1.40.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "shx": "^0.3.4",
    "typescript": "^5.6.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "jules",
    "google",
    "mcp",
    "modelcontextprotocol",
    "automation",
    "ai",
    "coding-assistant",
    "github",
    "code-review"
  ],
  "author": "Sami Halawa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcelb1200/JCLAW.git"
  }
}
